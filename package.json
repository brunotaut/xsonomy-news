{
  "name": "xsonomy-news",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "xSonomy UAV/C-UAS news feed — daily RSS ingest into Supabase, static site on GitHub Pages.",
  "scripts": {
    "ingest": "node scripts/ingest.mjs",
    "ingest:dry": "node scripts/ingest.mjs --dry",
    "backfill": "node scripts/backfill.mjs --days 300",
    "analyze:backfill": "node scripts/analyze-backfill.mjs",
    "analyze:backfill:dry": "node scripts/analyze-backfill.mjs --dry",
    "enrich:companies": "node scripts/enrich-companies.mjs",
    "enrich:companies:dry": "node scripts/enrich-companies.mjs --dry --max 10",
    "resolve": "node scripts/resolve-entities.mjs",
    "resolve:dry": "node scripts/resolve-entities.mjs --dry --max 50",
    "build": "node scripts/generate.mjs",
    "digest": "node scripts/digest.mjs --period day",
    "digest:week": "node scripts/digest.mjs --period week",
    "digest:dry": "node scripts/digest.mjs --period day --dry",
    "test": "node scripts/test-parser.mjs && node scripts/test-digest.mjs"
  },
  "engines": { "node": ">=20" }
}
